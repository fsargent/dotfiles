# Get the default branch name for the current repository
# Tries remote HEAD first, then falls back to checking for common branch names
git_default_branch() {
  # Try to get from remote HEAD (fastest, local lookup)
  local branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')

  if [ -n "$branch" ]; then
    echo "$branch"
    return
  fi

  # Fallback: check which common default branches exist on remote
  for candidate in main master develop; do
    if git show-ref --verify --quiet "refs/remotes/origin/$candidate" 2>/dev/null; then
      echo "$candidate"
      return
    fi
  done

  # Last resort fallback
  echo "main"
}

# Checkout default branch (auto-detects main/master/develop)
gcm() {
  git checkout "$(git_default_branch)"
}

