# Delete all merged branches except default and protected branches
gbda() {
  local default_branch=$(git_default_branch)
  git branch --no-color --merged | command grep -vE "^(\*|\s*(${default_branch}|master|main|develop|dev)\s*$)" | command xargs -n 1 git branch -d
}
