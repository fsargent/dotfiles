# Default Graphite create/submit to AI-generated metadata unless overridden.
gt() {
  if [ "$1" = "submit" ] || [ "$1" = "create" ]; then
    local subcommand="$1"
    shift

    for arg in "$@"; do
      if [ "$arg" = "--ai" ] || [ "$arg" = "--no-ai" ]; then
        command gt "$subcommand" "$@"
        return
      fi
    done

    command gt "$subcommand" --ai "$@"
    return
  fi

  command gt "$@"
}

# GAR (Google Artifact Registry) login via Workforce Identity Federation.
# Creates login config at ~/.config/gcp/gcp-gar-viewer, then runs gcloud auth login.
# Run `gcloud auth configure-docker us-docker.pkg.dev` once per machine for Docker pulls.
gar-login() {
  local config_dir=~/.config/gcp
  local config_file="${config_dir}/gcp-gar-viewer"
  mkdir -p "$config_dir"
  gcloud iam workforce-pools create-login-config \
    locations/global/workforcePools/polaris-pool-gar-viewer/providers/polaris-provider-gar-viewer \
    --output-file="$config_file" &&
    gcloud auth login --login-config="$config_file"
}

# Auto rebase: fetch latest and rebase current branch on origin's default branch
arb() {
  local default_branch=$(git_default_branch)
  git fetch origin && git rebase "origin/${default_branch}"
}

# Git Checkout Interactive function that works regardless of current directory's mise environment
gci() {
  # Use mise exec to run gci with the correct node environment
  # This will use the node version from your global mise config or a .tool-versions file
  mise exec node@latest -- npx git-checkout-interactive "$@"
}

# Git worktree add with automatic path creation
# Usage: gwa <branch-name> [additional-git-worktree-add-args]
# Creates worktree at ../<repo-name>.worktrees/<branch-name>
gwa() {
  if [ -z "$1" ]; then
    echo "Usage: gwa <branch-name> [additional-git-worktree-add-args]"
    echo "Example: gwa feature-branch"
    return 1
  fi

  local branch_name="$1"
  shift  # Remove first argument, keep rest for git worktree add

  # Get the repository root directory name
  local repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [ -z "$repo_root" ]; then
    echo "Error: Not in a git repository"
    return 1
  fi

  local repo_name=$(basename "$repo_root")
  local worktree_path="../${repo_name}.worktrees/${branch_name}"

  # Create the worktree
  git worktree add "$worktree_path" "$branch_name" "$@"
}

# Kill process(es) running on a specific port or port range
killport() {
  if [ -z "$1" ]; then
    echo "Usage: killport <port_number|port_range>"
    echo "Examples:"
    echo "  killport 3000        # Kill process on port 3000"
    echo "  killport 3000-3015   # Kill processes on ports 3000 through 3015"
    return 1
  fi

  local input=$1
  local ports=()
  local killed_pids=()
  local total_killed=0

  # Check if input contains a range (has a dash)
  if [[ $input == *-* ]]; then
    # Parse range
    local start_port=${input%-*}
    local end_port=${input#*-}

    # Validate range
    if ! [[ "$start_port" =~ ^[0-9]+$ ]] || ! [[ "$end_port" =~ ^[0-9]+$ ]]; then
      echo "❌ Invalid port range format. Use: start_port-end_port (e.g., 3000-3015)"
      return 1
    fi

    if [ $start_port -gt $end_port ]; then
      echo "❌ Start port must be less than or equal to end port"
      return 1
    fi

    echo "🔍 Scanning ports $start_port-$end_port for running processes..."

    # Generate port range
    for ((port=start_port; port<=end_port; port++)); do
      ports+=($port)
    done
  else
    # Single port
    if ! [[ "$input" =~ ^[0-9]+$ ]]; then
      echo "❌ Invalid port number: $input"
      return 1
    fi
    ports=($input)
  fi

  # Process each port
  for port in "${ports[@]}"; do
    local pids=$(lsof -ti :$port 2>/dev/null)

    if [ -n "$pids" ]; then
      echo "\n=== Port $port ==="
      lsof -i :$port 2>/dev/null

      echo "Killing processes on port $port: $pids"
      kill -9 $pids 2>/dev/null

      # Track killed PIDs (avoid duplicates)
      for pid in $pids; do
        if [[ ! " ${killed_pids[@]} " =~ " $pid " ]]; then
          killed_pids+=($pid)
        fi
      done

      total_killed=$((total_killed + $(echo $pids | wc -w)))
    fi
  done

  if [ $total_killed -eq 0 ]; then
    if [ ${#ports[@]} -eq 1 ]; then
      echo "No processes found running on port ${ports[0]}"
    else
      echo "No processes found running on ports $start_port-$end_port"
    fi
    return 0
  fi

  # Verify processes were killed
  sleep 1
  echo "\n📊 Summary:"
  echo "Total processes killed: $total_killed"
  echo "Unique PIDs killed: ${killed_pids[*]}"

  # Check for any remaining processes
  local remaining_count=0
  for port in "${ports[@]}"; do
    local remaining=$(lsof -ti :$port 2>/dev/null)
    if [ -n "$remaining" ]; then
      remaining_count=$((remaining_count + 1))
    fi
  done

  if [ $remaining_count -eq 0 ]; then
    echo "✅ All processes successfully killed"
  else
    echo "⚠️  $remaining_count port(s) may still have running processes"
  fi
}
